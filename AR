<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Scan a marker – Cake AR</title>
    <!-- A-Frame + AR.js -->
    <script src="https://aframe.io/releases/1.4.0/aframe.min.js"></script>
    <script src="https://raw.githack.com/AR-js-org/AR.js/master/aframe/build/aframe-ar.js"></script>
    <style>
        body { margin:0; overflow:hidden; }
        #instructions {
            position: absolute; bottom: 20px; left: 20px;
            background: rgba(0,0,0,0.6); color: white; padding: 10px;
            font-family: sans-serif; border-radius: 8px;
        }
    </style>
</head>
<body>
    <a-scene embedded arjs="sourceType: webcam; debugUIEnabled: false;">

        <!-- THE MARKER YOU MUST SCAN (Hiro preset) -->
        <a-marker preset="hiro">
            <!-- CAKE! (built from simple shapes) -->
            <a-entity position="0 0.5 0">
                <!-- Bottom cake layer -->
                <a-cylinder radius="0.3" height="0.2" color="#D2691E" position="0 0 0"></a-cylinder>
                <!-- Middle cake layer -->
                <a-cylinder radius="0.25" height="0.2" color="#D2691E" position="0 0.22 0"></a-cylinder>
                <!-- Top cake layer -->
                <a-cylinder radius="0.2" height="0.15" color="#D2691E" position="0 0.4 0"></a-cylinder>
                <!-- Frosting / icing lines (just for decoration) -->
                <a-torus radius="0.21" radius-tubular="0.02" color="#FFB6C1" position="0 0.48 0"></a-torus>
                <a-torus radius="0.26" radius-tubular="0.02" color="#FFB6C1" position="0 0.3 0"></a-torus>
                <!-- Candle -->
                <a-cylinder radius="0.03" height="0.15" color="#FFFFFF" position="0 0.55 0"></a-cylinder>
                <!-- Flame -->
                <a-sphere radius="0.04" color="#FF4500" position="0 0.63 0"></a-sphere>
            </a-entity>
        </a-marker>

        <!-- The camera -->
        <a-entity camera></a-entity>
    </a-scene>

    <div id="instructions">
        📷 Point your camera at the <strong>Hiro marker</strong><br>
        (Search "Hiro marker" and print the black square)
    </div>
</body>
</html>
